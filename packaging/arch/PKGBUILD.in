pkgname=cockpit-samba
pkgver=VERSION
pkgrel=1
pkgdesc='Cockpit module for managing Samba file shares'
arch=('x86_64')
url='https://github.com/hrhnick/cockpit-samba'
license=(LGPL)
source=("SOURCE")
sha256sums=('SKIP')

package() {
  depends=(cockpit)
  cd $pkgname
  make DESTDIR="$pkgdir" install PREFIX=/usr
}
